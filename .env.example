# Copy to .env and fill in. Never commit .env.

# News headlines (https://newsapi.org/)
NEWS_API_KEY=

# Groq OpenAI-compatible API (https://console.groq.com/)
GROQ_API_KEY=
# Optional: override default llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.1-8b-instant

# Optional tuning
# MODEL_CACHE_TTL_SEC=3600
# MODEL_CACHE_MAX_KEYS=24
# SENTIMENT_RETURN_COEF=0.004
# NEWS_HEADLINE_CACHE_TTL_SEC=900
# GROQ_MAX_WORKERS=8
