# Copy to .env and fill in. Never commit .env.

# News headlines (https://newsapi.org/)
NEWS_API_KEY=

# Groq (https://console.groq.com/) — sentiment + chat tool-calling
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# --- Supabase (OPTIONAL) ---
# The API runs fine with no Supabase vars: every request is anonymous, forecasts
# are not saved to a DB, and tier limits follow the "public" rules (+ rate limits).
#
# When BOTH are set, the backend can verify JWTs (Authorization: Bearer ...),
# load profiles/tiers, persist forecasts after /api/predict, and track daily usage:
#   SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (Dashboard → Settings → API → service_role)
# SUPABASE_URL alone does nothing — you need the service_role secret and tables.
# Apply schema once in the Supabase SQL editor: supabase/schema.sql
# Legacy alias: SUPABASE_SERVICE_KEY (same as SUPABASE_SERVICE_ROLE_KEY)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
#
# Browser sign-in (Dashboard → Settings → API → anon public key). Never use service_role in the UI.
# SUPABASE_ANON_KEY=

# HTTP / deploy
# ENVIRONMENT=production              # disables OpenAPI docs
# ALLOWED_HOSTS=localhost,127.0.0.1,yourapp.onrender.com
# CORS_ORIGINS=http://localhost:8000,https://yourapp.onrender.com
# ENABLE_HSTS=true                    # only behind HTTPS
# CHAT_ALLOW_PUBLIC=1                 # allow /api/chat without login (local demo only)
# KILL_SWITCH=0

# Optional tuning
# MODEL_CACHE_TTL_SEC=3600
# MODEL_CACHE_MAX_KEYS=24
# SENTIMENT_RETURN_COEF=0.004
# NEWS_HEADLINE_CACHE_TTL_SEC=900
# GROQ_MAX_WORKERS=8
# AUDIT_LOG_PATH=logs/audit.log
