# Copy to .env and fill in values. Never commit .env.

# Core API keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
NEWS_API_KEY=

# Supabase (required for account/watchlist/history/admin features)
# Apply schema once in Supabase SQL editor: supabase/schema.sql
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy alias (optional): SUPABASE_SERVICE_KEY=

# OAuth feature flags for account buttons in UI/bootstrap
# Set to 1 only after provider credentials are configured in Supabase Auth.
SUPABASE_OAUTH_GOOGLE=0
SUPABASE_OAUTH_GITHUB=0

# Chat behavior
# Set to 0 in production if you want chat to require sign-in.
CHAT_ALLOW_PUBLIC=1

# Production deploy (Render)
# ENVIRONMENT=production
# ALLOWED_HOSTS=localhost,127.0.0.1,yourapp.onrender.com
# CORS_ORIGINS=http://localhost:8000,https://yourapp.onrender.com
# ENABLE_HSTS=true
# KILL_SWITCH=0

# Optional tuning
# MODEL_CACHE_TTL_SEC=3600
# MODEL_CACHE_MAX_KEYS=24
# SENTIMENT_RETURN_COEF=0.004
# NEWS_HEADLINE_CACHE_TTL_SEC=900
# GROQ_MAX_WORKERS=8
# AUDIT_LOG_PATH=logs/audit.log
